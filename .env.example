# AIO Media Manager Environment Variables

# API Configuration
VITE_PLEX_CLIENT_IDENTIFIER=aio-media-manager
VITE_PLEX_PRODUCT=AIO Media Manager
VITE_PLEX_VERSION=0.1.0
VITE_PLEX_PLATFORM=Web

# External Metadata Providers (Optional)
# Get your API keys from the respective services for best experience.
# The application includes fallback public keys with rate limits, but your own keys are recommended.
#
# Get your API keys from:
# - TMDB: https://www.themoviedb.org/settings/api (Free, 40 req/10sec)
# - OMDb (IMDB): https://www.omdbapi.com/apikey.aspx (Free, 1000 req/day)
# - TVDB: https://thetvdb.com/dashboard/account/apikeys (Free, 100k req/month)
# - Discogs: https://www.discogs.com/settings/developers (Free, 60 req/min authenticated)
# - Fanart.tv: https://fanart.tv/get-an-api-key/ (Free, 2000 req/day)
# - Last.fm: https://www.last.fm/api (Free, 5 req/sec)
# - AlbumArtExchange: https://www.albumartexchange.com (No API key required, web scraping)
# - MusicBrainz: No API key required (Free, 1 req/sec)
# - YouTube Trailers: No API key required (Web scraping)
#
# Note: If you don't provide keys, the app will use shared public keys (slower, rate limited).
# For Discogs, a personal key is required for good rate limits.

VITE_TMDB_API_KEY=your_tmdb_api_key_here
# VITE_IMDB_API_KEY=your_omdb_api_key_here
# VITE_TVDB_API_KEY=your_tvdb_api_key_here
# VITE_DISCOGS_API_KEY=your_discogs_key_here
# VITE_DISCOGS_API_SECRET=your_discogs_secret_here
# VITE_FANART_API_KEY=your_fanart_api_key_here
# VITE_LASTFM_API_KEY=your_lastfm_api_key_here

# Development
VITE_DEV_SERVER_URL=http://localhost:5173
